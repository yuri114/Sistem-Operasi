{
    "configurations": [
        {
            "name": "OS Dev (GCC i686)",
            "includePath": [
                "${workspaceFolder}/src/**"
            ],
            "defines": [
                "__GNUC__",
                "__i386__",
                "__x86__"
            ],
            "compilerPath": "C:/msys64/mingw32/bin/i686-w64-mingw32-gcc.exe",
            "compilerArgs": [
                "-m32",
                "-ffreestanding",
                "-fno-builtin",
                "-nostdlib",
                "-nostartfiles",
                "-fno-pic"
            ],
            "cStandard": "gnu11",
            "cppStandard": "gnu++17",
            "intelliSenseMode": "linux-gcc-x86",
            "browse": {
                "path": [
                    "${workspaceFolder}/src/**"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ],
    "version": 4
}
